# Operating-system and editor files
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.code-workspace
*~
*.swp
*.swo

# Local AI-assistant settings
.claude/settings.local.json

# Local environment and secrets
.env
.env.*
!.env.example
.venv/
venv/
env/
ENV/

# Python bytecode, caches, and packaging artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.egg-info/
.eggs/
build/
dist/

# Generated BrineWatch mission and benchmark artifacts, EXCEPT the curated
# committed evidence packages (see brinewatch/outputs/README.md)
brinewatch/outputs/*
!brinewatch/outputs/README.md
!brinewatch/outputs/visual/
!brinewatch/outputs/sonar_visibility/
!brinewatch/outputs/localization/
!brinewatch/outputs/full_mission/

